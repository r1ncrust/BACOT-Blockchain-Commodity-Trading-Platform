{
  "name": "commodity-trading-platform",
  "version": "1.0.0",
  "description": "Commodity Trading Platform on Ethereum",
  "main": "index.js",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.ts --network sepolia",
    "verify": "hardhat verify --network sepolia",
    "start:backend": "cd backend && npm start",
    "dev": "concurrently \"npm run start:backend\" \"cd frontend && npm start\"",
    "typechain": "hardhat typechain"
  },
  "keywords": [
    "ethereum",
    "solidity",
    "commodity",
    "trading",
    "blockchain"
  ],
  "author": "Commodity Trading Platform",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.3",
    "@openzeppelin/contracts-upgradeable": "^4.9.5",
    "@typechain/ethers-v6": "^0.4.3",
    "@types/mocha": "^9.1.0",
    "@types/node": "^18.0.0",
    "concurrently": "^7.6.0",
    "dotenv": "^16.0.3",
    "ethers": "^6.13.2",
    "hardhat": "^2.28.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "eth-sig-util": "^3.0.1",
    "express": "^4.18.2",
    "ipfs-http-client": "^56.0.3",
    "multer": "^1.4.5-lts.1",
    "web3": "^4.0.2"
  }
}
